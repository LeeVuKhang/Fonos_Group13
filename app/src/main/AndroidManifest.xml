<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".FonosApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Fonos_Group13">

        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.Fonos_Group13.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" />
        <activity android:name=".RegisterActivity" />
        <activity android:name=".DiscoverActivity" />
        <activity android:name=".SearchActivity" />
        <activity android:name=".LibraryActivity" />
        <activity android:name=".ProfileActivity" />
        <activity android:name=".CreateAudiobookActivity" />
        <activity android:name=".ManageChapterActivity" />
        <activity android:name=".MyUploadsActivity" />
        <activity android:name=".AudioPreferencesActivity" />
        <activity android:name=".BookDetailActivity" />
        <activity
            android:name=".AiChatActivity"
            android:exported="false" />
        <activity
            android:name=".ActivityReader"
            android:exported="false" />

        <service
            android:name=".audio.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <service
            android:name=".notifications.GenerationNotificationMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
