<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_chat_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/ai_chat_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ai_chat_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/accessibility_back"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_logout"
            app:tint="@color/text_main" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ai_chat_title"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ai_chat_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_chat_clear"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/ai_clear"
            android:textAllCaps="false"
            android:textColor="@color/accent_text"
            app:backgroundTint="@android:color/transparent" />
    </LinearLayout>

    <Spinner
        android:id="@+id/ai_scope_spinner"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/edittext_bg_new"
        android:contentDescription="@string/ai_scope"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ai_chat_header" />

    <LinearLayout
        android:id="@+id/ai_starters_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ai_scope_spinner">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_starter_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="@string/ai_starter_summary"
            android:textAllCaps="false"
            android:textColor="@color/accent_text"
            android:textSize="12sp"
            app:backgroundTint="@color/accent_soft"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_starter_themes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="@string/ai_starter_themes"
            android:textAllCaps="false"
            android:textColor="@color/accent_text"
            android:textSize="12sp"
            app:backgroundTint="@color/accent_soft"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_starter_characters"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="@string/ai_starter_characters"
            android:textAllCaps="false"
            android:textColor="@color/accent_text"
            android:textSize="12sp"
            app:backgroundTint="@color/accent_soft"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/ai_messages_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toTopOf="@+id/ai_status_panel"
        app:layout_constraintTop_toBottomOf="@id/ai_starters_scroll">

        <LinearLayout
            android:id="@+id/ai_messages_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/ai_status_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toTopOf="@id/ai_input_panel">

        <ProgressBar
            android:id="@+id/ai_loading"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ai_status_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:accessibilityLiveRegion="polite"
            android:textColor="@color/error_text"
            android:textSize="13sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_retry"
            android:textAllCaps="false"
            android:visibility="gone"
            app:backgroundTint="@color/accent_soft" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ai_input_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ai_question_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="52dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/control_stroke"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/ai_question_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="@string/ai_question_hint"
                android:imeOptions="actionSend"
                android:importantForAutofill="no"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLength="1000"
                android:maxLines="4"
                android:minHeight="52dp"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_send"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="@string/ai_send"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:cornerRadius="16dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
