<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Account Settings"
        android:textColor="@color/text_dark"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Choose the name shown on your profile."
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/dialog_display_name"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/edittext_bg_new"
        android:hint="Display name"
        android:inputType="textCapWords"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:selectAllOnFocus="true"
        android:singleLine="true"
        android:textColor="@color/text_dark"
        android:textColorHint="@color/text_muted"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dialog_cancel"
            android:layout_width="96dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_chip_white"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialog_save"
            android:layout_width="96dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_chip_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Save"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
