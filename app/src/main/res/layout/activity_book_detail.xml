<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/accessibility_back"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_logout"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="@string/app_lumina"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="132dp"
                    android:layout_height="176dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:id="@+id/detail_cover"
                        android:importantForAccessibility="no"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_cover_placeholder"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Audiobook"
                        android:textColor="@color/accent_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_title"
                        android:accessibilityHeading="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="serif"
                        android:text=""
                        android:textColor="@color/text_dark"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_author"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text=""
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/detail_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/detail_rating_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/community_no_ratings"
                        android:textColor="@color/accent_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_save_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/community_zero_saves"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btn_play_resume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="Play or resume"
                    android:src="@drawable/ic_play"
                    app:backgroundTint="@color/accent_green"
                    app:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/btn_save_book"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="18dp"
                    android:alpha="0.45"
                    android:clickable="true"
                    android:contentDescription="Save audiobook"
                    android:focusable="true"
                    android:padding="13dp"
                    android:src="@drawable/ic_bookmark"
                    app:tint="@color/accent" />

                <ImageView
                    android:id="@+id/btn_download_all"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="18dp"
                    android:contentDescription="Download all chapters"
                    android:focusable="true"
                    android:padding="13dp"
                    android:src="@drawable/ic_download"
                    app:tint="@color/accent" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ask_ai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:enabled="false"
                android:minHeight="52dp"
                android:text="@string/ai_ask"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/accent"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/ai_availability_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/detail_message"
                android:accessibilityLiveRegion="polite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_empty_state"
                android:gravity="center"
                android:padding="18dp"
                android:text=""
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_publish_audiobook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:layout_marginTop="18dp"
                android:text="Publish Audiobook"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="gone"
                app:backgroundTint="@color/accent"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_chapter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:layout_marginTop="12dp"
                android:text="Add Chapter"
                android:textAllCaps="false"
                android:textColor="@color/accent_text"
                android:textSize="16sp"
                android:visibility="gone"
                app:backgroundTint="@color/accent_soft"
                app:cornerRadius="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Chapters"
                android:accessibilityHeading="true"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/chapters_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/community_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/community_reviews_title"
                    android:accessibilityHeading="true"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <RatingBar
                    android:id="@+id/review_rating_input"
                    android:contentDescription="@string/accessibility_your_rating"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:numStars="5"
                    android:rating="0"
                    android:stepSize="1" />

                <TextView
                    android:id="@+id/review_comment_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:labelFor="@id/review_comment_input"
                    android:text="Comment (optional)"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/review_comment_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edittext_bg_new"
                    android:gravity="top|start"
                    android:inputType="textCapSentences|textMultiLine"
                    android:importantForAutofill="no"
                    android:maxLength="1000"
                    android:minHeight="112dp"
                    android:padding="14dp" />

                <TextView
                    android:id="@+id/review_character_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="@string/community_character_count_zero"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_delete_review"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/community_delete_action"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:backgroundTint="@android:color/transparent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_submit_review"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/community_submit_review"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/accent" />
                </LinearLayout>

                <TextView
                    android:id="@+id/reviews_message"
                    android:accessibilityLiveRegion="polite"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:textColor="@color/text_muted"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/reviews_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_load_more_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/community_load_more"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:backgroundTint="@color/accent_soft" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
