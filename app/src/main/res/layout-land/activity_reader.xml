<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reader_bg">

    <!-- 1. Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivExit"
            android:contentDescription="@string/accessibility_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_logout"
            app:tint="@color/text_main"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAskAiReader"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:alpha="0.45"
                android:enabled="false"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="AI"
                android:textAllCaps="false"
                android:textColor="@color/accent_text"
                app:backgroundTint="@color/accent_soft"
                app:cornerRadius="16dp" />

            <ImageView
                android:id="@+id/ivDownloadAudio"
                android:contentDescription="@string/accessibility_download_chapter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_download"
                app:tint="@color/text_main" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2. Content Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/playerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvChapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginTop="32dp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvBookTitle"
                android:accessibilityHeading="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textSize="32sp"
                android:fontFamily="serif"
                android:textColor="@color/text_main"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvAiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvBookContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="18sp"
                android:fontFamily="serif"
                android:lineSpacingExtra="8dp"
                android:layout_marginTop="40dp"
                android:textColor="@color/text_main" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 3. Player Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/playerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/player_bg"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="-20dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <!-- Đặt marginBottom âm để giấu phần bo góc dưới nếu muốn giống ảnh -->

        <LinearLayout
            android:id="@+id/playerControlsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="44dp">

            <!-- SeekBar & Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="04:12"
                    android:fontFeatureSettings="tnum"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                <SeekBar
                    android:id="@+id/seekBar"
                    android:contentDescription="@string/accessibility_playback_position"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="@color/accent_green"
                    android:thumbTint="@color/accent_green"/>
                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18:45"
                    android:fontFeatureSettings="tnum"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Controls -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:id="@+id/tvPlaybackSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:contentDescription="@string/accessibility_playback_speed"
                    android:text="1.0x"
                    android:fontFeatureSettings="tnum"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center">
                    <ImageView android:id="@+id/btnSkipBack" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:contentDescription="@string/accessibility_previous_chapter" android:focusable="true" android:padding="8dp" android:src="@drawable/ic_skip_back" />
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:contentDescription="@string/accessibility_play_audiobook"
                        android:src="@drawable/ic_play"
                        app:backgroundTint="@color/accent_green"
                        app:tint="@android:color/white" />
                    <ImageView android:id="@+id/btnSkipForward" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:contentDescription="@string/accessibility_next_chapter" android:focusable="true" android:padding="8dp" android:src="@drawable/ic_skip_forward" />
                </LinearLayout>

                <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_settings" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:alpha="0.45" android:enabled="false" android:importantForAccessibility="no" android:padding="12dp"/>
            </RelativeLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
